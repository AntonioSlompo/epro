tem value=\"MT\">Metro</SelectItem>\n                                                    <SelectItem value=\"KG\">Quilo</SelectItem>\n                                                    <SelectItem value=\"KIT\">Kit</SelectItem>\n                                                    <SelectItem value=\"HR\">Hora</SelectItem>\n                                                    <SelectItem value=\"OTHER\">Outro</SelectItem>\n                                                </SelectContent>\n                                            </Select>\n                                        </FormControl>\n                                        <FormMessage />\n                                    </FormItem>\n                                )}\n                            />\n                            <FormField\n                                control={form.control}\n                                name=\"warrantyMonths\"\n                                render={({ field }) => (\n                                    <FormItem>\n                                        <FormLabel>Garantia (Meses)</FormLabel>\n                                        <FormControl>\n                                            <Input type=\"number\" min={0} {...field} value={field.value || ''} onChange={(e) => field.onChange(e.target.value ? Number(e.target.value) : null)} />\n                                        </FormControl>\n                                        <FormMessage />\n                                    </FormItem>\n                                )}\n                            />\n                            <FormField\n                                control={form.control}\n                                name=\"minStock\"\n                                render={({ field }) => (\n                                    <FormItem>\n                                        <FormLabel>Estoque M├¡nimo</FormLabel>\n                                        <FormControl>\n             